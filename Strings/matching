// Custom hash function for pair/struct if using double hashing
struct SafeHash {
    static uint64_t splitmix64(uint64_t x) {
        x += 0x9e3779b97f4a7c15;
        x = (x ^ (x >> 30)) * 0xbf58476d1ce4e5b9;
        x = (x ^ (x >> 27)) * 0x94d049bb133111eb;
        return x ^ (x >> 31);
    }
    size_t operator()(uint64_t x) const {
        static const uint64_t FIXED_RANDOM = 123456789; // use random_device in real contest
        return splitmix64(x + FIXED_RANDOM);
    }
};

struct DynamicPatternCounter {
    int n, block_size, num_blocks;
    string text;
    
    const long long MOD = 1e9 + 7;
    const long long BASE = 313;
    vector<long long> power;

    // A hash map per block storing: Substring_Hash -> Frequency
    vector<unordered_map<long long, int, SafeHash>> block_hashes;

    void init(const string& s) {
        text = s;
        n = text.length();
        block_size = sqrt(n) + 1;
        num_blocks = (n + block_size - 1) / block_size;
        
        power.assign(n + 1, 1);
        for (int i = 0; i < n; i++) power[i + 1] = (power[i] * BASE) % MOD;

        block_hashes.resize(num_blocks);
        for (int i = 0; i < num_blocks; i++) {
            rebuild_block(i);
        }
    }

    // Recomputes all unique substring hashes inside a single block in O(B^2)
    void rebuild_block(int b_idx) {
        block_hashes[b_idx].clear();
        int L = b_idx * block_size;
        int R = min(n - 1, L + block_size - 1);

        // Compute local rolling hashes inside this block
        for (int i = L; i <= R; i++) {
            long long current_hash = 0;
            for (int j = i; j <= R; j++) {
                current_hash = (current_hash * BASE + text[j]) % MOD;
                block_hashes[b_idx][current_hash]++;
            }
        }
    }

    // O(sqrt(N)) Character Update
    void update_char(int idx, char c) {
        if (text[idx] == c) return;
        text[idx] = c;
        int b_idx = idx / block_size;
        rebuild_block(b_idx); // local rebuild
    }

    // Helper to extract a rolling hash from a raw substring window manually
    long long compute_raw_hash(int L, int R) {
        long long h = 0;
        for(int i = L; i <= R; i++) h = (h * BASE + text[i]) % MOD;
        return h;
    }

    // O(sqrt(N)) Count Query using ONLY a hash and length
    int count_occurrences(long long target_hash, int len) {
        if (len > n) return 0;
        int total_count = 0;

        // 1. Count instances completely contained inside blocks
        for (int i = 0; i < num_blocks; i++) {
            int L = i * block_size;
            int R = min(n - 1, L + block_size - 1);
            int available = R - L + 1;

            if (len <= available) {
                if (block_hashes[i].count(target_hash)) {
                    total_count += block_hashes[i][target_hash];
                }
            }
        }

        // 2. Count instances crossing block boundaries manually
        // We look at windows of size 'len' that straddle across block edges
        for (int i = 0; i < num_blocks - 1; i++) {
            int boundary_idx = (i * block_size) + block_size - 1; // last element of block i
            
            // The window must cover boundary_idx and boundary_idx + 1
            int start_min = max(0, boundary_idx - len + 1);
            int start_max = min(boundary_idx, n - len);

            for (int start = start_min; start <= start_max; start++) {
                int end = start + len - 1;
                
                // If this window is completely inside a single block, skip it 
                // (it was already counted in step 1)
                if (start / block_size == end / block_size) continue;

                // Verify hash
                if (compute_raw_hash(start, end) == target_hash) {
                    total_count++;
                }
            }
        }

        return total_count;
    }
};

int main() {
    string text = "aaaaa"; // 5 a's
    DynamicPatternCounter dpc;
    dpc.init(text);

    long long hash_aa = dpc.compute_raw_hash(0, 1); // Get hash of "aa"

    // Originally, "aa" occurs 4 times in "aaaaa"
    cout << "Occurrences of 'aa': " << dpc.count_occurrences(hash_aa, 2) << "\n";

    // Change middle character: text becomes "aabaa"
    dpc.update_char(2, 'b');

    // Now, "aa" should only occur 2 times (at the beginning and at the end)
    cout << "Occurrences of 'aa' after update: " << dpc.count_occurrences(hash_aa, 2) << "\n";

    return 0;
}
