struct DynamicStringCounter {
    int N, sz, lst;
    vector<vector<int>> nxt;
    vector<int> lnk, len, cnt;

    // Initialize and build the Suffix Automaton on string X
    void init(const string& x) {
        N = x.size();
        int mx = 2 * N + 5;
        
        nxt.assign(mx, vector<int>(26, 0));
        lnk.assign(mx, 0); len.assign(mx, 0); cnt.assign(mx, 0);
        
        lnk[0] = -1; sz = 1; lst = 0;

        for (char c : x) {
            int cur = sz++, p = lst, id = c - 'a';
            len[cur] = len[p] + 1; cnt[cur] = 1;
            while (p != -1 && !nxt[p][id]) nxt[p][id] = cur, p = lnk[p];
            if (p == -1) lnk[cur] = 0;
            else {
                int q = nxt[p][id];
                if (len[p] + 1 == len[q]) lnk[cur] = q;
                else {
                    int cl = sz++; len[cl] = len[p] + 1;
                    nxt[cl] = nxt[q]; lnk[cl] = lnk[q];
                    while (p != -1 && nxt[p][id] == q) nxt[p][id] = cl, p = lnk[p];
                    lnk[q] = lnk[cur] = cl;
                }
            }
            lst = cur;
        }

        // Compute exact match frequencies via topological / length sorting
        vector<int> o(sz); iota(o.begin(), o.end(), 0);
        sort(o.begin(), o.end(), [&](int a, int b) { return len[a] > len[b]; });
        for (int u : o) if (lnk[u] != -1) cnt[lnk[u]] += cnt[u];
    }

    // Answers the query for a completely arbitrary string Y in O(|Y|) time
    int query(const string& y) {
        int u = 0;
        for (char c : y) {
            int id = c - 'a';
            u = nxt[u][id];
            if (!u) return 0; // If transition fails, Y does not exist in X
        }
        return cnt[u];
    }
};
