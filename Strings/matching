struct SAAM {
    int N, sz, lst, lg;
    vector<vector<int>> nxt, up;
    vector<int> lnk, len, cnt;
    vector<int> match_len, match_node;
 
    // Call this with 0-indexed strings X and Y
    void init(const string& x, const string& y) {
        N = x.size();
        int mx = 2 * N + 5;
        lg = 32 - __builtin_clz(mx);
        
        nxt.assign(mx, vector<int>(26, 0));
        up.assign(mx, vector<int>(lg, 0));
        lnk.assign(mx, 0); len.assign(mx, 0); cnt.assign(mx, 0);
        
        lnk[0] = -1; sz = 1; lst = 0;
 
        // 1. Build Suffix Automaton for X
        for (char c : x) {
            int cur = sz++, p = lst, id = c - 'a';
            len[cur] = len[p] + 1; cnt[cur] = 1;
            while (p != -1 && !nxt[p][id]) nxt[p][id] = cur, p = lnk[p];
            if (p == -1) lnk[cur] = 0;
            else {
                int q = nxt[p][id];
                if (len[p] + 1 == len[q]) lnk[cur] = q;
                else {
                    int cl = sz++; len[cl] = len[p] + 1;
                    nxt[cl] = nxt[q]; lnk[cl] = lnk[q];
                    while (p != -1 && nxt[p][id] == q) nxt[p][id] = cl, p = lnk[p];
                    lnk[q] = lnk[cur] = cl;
                }
            }
            lst = cur;
        }
 
        // 2. Compute accurate match frequencies via Radix/Length Sort
        vector<int> o(sz); iota(o.begin(), o.end(), 0);
        sort(o.begin(), o.end(), [&](int a, int b) { return len[a] > len[b]; });
        for (int u : o) if (lnk[u] != -1) cnt[lnk[u]] += cnt[u];
 
        // 3. Build Binary Lifting Table over Suffix Links
        for (int i = 0; i < sz; i++) up[i][0] = (lnk[i] == -1 ? 0 : lnk[i]);
        for (int j = 1; j < lg; j++) {
            for (int i = 0; i < sz; i++) {
                up[i][j] = up[up[i][j - 1]][j - 1];
            }
        }
 
        // 4. Precalculate the continuous matching sequence of Y on X
        int m = y.size();
        match_len.assign(m, 0); match_node.assign(m, 0);
        int u = 0, cur_l = 0;
        for (int i = 0; i < m; i++) {
            int id = y[i] - 'a';
            while (u != -1 && !nxt[u][id]) {
                u = lnk[u];
                if (u != -1) cur_l = len[u];
            }
            if (u == -1) { u = 0; cur_l = 0; }
            else { u = nxt[u][id]; cur_l++; }
            match_len[i] = cur_l;
            match_node[i] = u;
        }
    }
 
    // Jumps up to locate the exact node grouping corresponding to the length scope
    int get_state(int node, int target_len) {
        for (int i = lg - 1; i >= 0; i--) {
            if (len[up[node][i]] >= target_len) {
                node = up[node][i];
            }
        }
        return node;
    }
 
    // Expects STRICTLY 0-indexed query boundaries [l, r] from string Y
    int query(int l, int r) {
        if (l > r || l < 0 || r >= (int)match_len.size()) return 0;
        int target_len = r - l + 1;
 
        // If the max match ending at r is shorter than the window, it does not exist in X
        if (match_len[r] < target_len) return 0;
 
        int target_node = get_state(match_node[r], target_len);
        return cnt[target_node];
    }
};
