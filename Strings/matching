using namespace std;
struct HashPair {
    long long h1, h2;
    int query_L = -1;
    const string* src_str = nullptr;
    const void* hm_ptr = nullptr;
 
    bool operator==(const HashPair& o) const { return h1 == o.h1 && h2 == o.h2; }
    bool operator<(const HashPair& o) const { return h1 == o.h1 ? h2 < o.h2 : h1 < o.h1; }
};
 
struct HashManager {
    const long long MOD1 = 1e9 + 7;
    const long long MOD2 = 1e9 + 9;
    const long long B1 = 313;
    const long long B2 = 317;
 
    vector<long long> p1, p2;
    vector<long long> pref1, pref2;
    const string* base_string = nullptr;
 
    void init(const string& s) {
        base_string = &s;
        int n = s.length();
        p1.assign(n + 1, 1); p2.assign(n + 1, 1);
        pref1.assign(n + 1, 0); pref2.assign(n + 1, 0);
 
        for (int i = 0; i < n; i++) {
            p1[i + 1] = (p1[i] * B1) % MOD1;
            p2[i + 1] = (p2[i] * B2) % MOD2;
            pref1[i + 1] = (pref1[i] * B1 + s[i]) % MOD1;
            pref2[i + 1] = (pref2[i] * B2 + s[i]) % MOD2;
        }
    }
 
    HashPair get_hash(int L, int R) {
        if (L > R || L < 0 || base_string == nullptr || R >= (int)base_string->length()) 
            return {0, 0, -1, nullptr, nullptr};
        long long h1 = (pref1[R + 1] - (pref1[L] * p1[R - L + 1]) % MOD1) % MOD1;
        long long h2 = (pref2[R + 1] - (pref2[L] * p2[R - L + 1]) % MOD2) % MOD2;
        if (h1 < 0) h1 += MOD1;
        if (h2 < 0) h2 += MOD2;
        
        return {h1, h2, L, base_string, this};
    }
};
 
struct SFX {
    int n;
    string text;
    vector<int> sa;
 
    void build(const string& s) {
        this->n = s.length();
        this->text = s;
        string temp = s + '$';
        int N = temp.length();
        vector<int> p(N), c(N);
        {
            vector<pair<char, int>> a(N);
            for (int i = 0; i < N; i++) a[i] = {temp[i], i};
            sort(a.begin(), a.end());
            for (int i = 0; i < N; i++) p[i] = a[i].second;
            c[p[0]] = 0;
            for (int i = 1; i < N; i++) {
                c[p[i]] = (a[i].first == a[i - 1].first) ? c[p[i - 1]] : c[p[i - 1]] + 1;
            }
        }
        int k = 0;
        while ((1 << k) < N) {
            vector<int> p_next(N);
            for (int i = 0; i < N; i++) {
                p_next[i] = p[i] - (1 << k);
                if (p_next[i] < 0) p_next[i] += N;
            }
            vector<int> head(N, 0);
            for (int i = 0; i < N; i++) head[c[i]]++;
            vector<int> pref(N, 0);
            for (int i = 1; i < N; i++) pref[i] = pref[i - 1] + head[i - 1];
            for (int x : p_next) {
                int i = c[x];
                p[pref[i]] = x;
                pref[i]++;
            }
            vector<int> c_next(N);
            c_next[p[0]] = 0;
            for (int i = 1; i < N; i++) {
                pair<int, int> prev = {c[p[i - 1]], c[(p[i - 1] + (1 << k)) % N]};
                pair<int, int> curr = {c[p[i]], c[(p[i] + (1 << k)) % N]};
                c_next[p[i]] = (prev == curr) ? c_next[p[i - 1]] : c_next[p[i - 1]] + 1;
            }
            c = move(c_next);
            k++;
        }
 
        this->sa.resize(this->n);
        for (int i = 0; i < this->n; i++) {
            this->sa[i] = p[i + 1];
        }
    }
 
    // High performance O(log N) check unpacking the string metadata inside target_hash
    bool count_hash_occurrences(HashPair target_hash, int len) {
        if (len <= 0) return true;
        
        int y_start = target_hash.query_L;
        const string* target_str = target_hash.src_str;
        if (!target_str) return false;
 
        int low = 0, high = n - 1;
        while (low <= high) {
            int mid = low + (high - low) / 2;
            int start_pos = sa[mid];
 
            // Direct highly optimized character range compare matching
            int len_to_check = min(n - start_pos, len);
            int cmp = text.compare(start_pos, len_to_check, *target_str, y_start, len);
 
            if (cmp == 0) {
                if (len_to_check == len) return true; // Found the substring match!
                low = mid + 1; // Text ended early, look higher up alphabetically
            } else if (cmp < 0) {
                low = mid + 1;
            } else {
                high = mid - 1;
            }
        }
        return false;
    }
};
