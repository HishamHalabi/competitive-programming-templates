void testCase()   {
 


    int n  , m  ; 
    cin >> n >> m ;
    
    
    std::vector<vector <  int >>  g   =  vector <vector < int >> (n+1);
    
    for  (int  i = 1; i <=m ; ++i) {
        int  u , v; 
        cin >> u >> v; 
        g[u].push_back(v);
        g[v].push_back(u) ; 
       
    }
    
    
    vector< vector <int  >  > dis(n+1);
    vector  <vector  < pair <  int  , int >>>par(n+1 , vector < pair< int, int >  > (3 ,{-1,-1})) ; 
    
    std::queue<pair < int , int > >q ; 
    q.push({1, 0}) ; 
    dis[1].push_back(0) ; 
    
    while(q.size()) { 
        auto [nd , pth] = q.front(); 
        q.pop() ;
       
        int current_state = 0;
        if (dis[nd].size() > 1 && dis[nd][1] == pth) {
            current_state = 1;
        }

        for (auto ch :g[nd]) {
               if (dis[ch].size() == 2)continue ;
               
               if (par[nd][current_state + 1].first == ch) continue;

               dis[ch].push_back(pth+1);
               par[ch][dis[ch].size()]  = {nd, current_state + 1}; 
               q.push({ch , pth+1}); 
        }
    }
    
    
    int mn =  1e9 ; 
    for (int i  =2; i <=n;  ++i){
             if (dis[i].size()   >1) {
                 mn = min(mn,dis[i][0]  + dis[i][1]) ;
             }
    }
    
    
    if (mn > 1e7)  {
        cout<<"impossible\n" ; 
        return ; 
    }
 

    
    for (int i  =2; i <=n;  ++i){
             if (dis[i].size()   >1 and dis[i][0] +  dis[i][1] == mn) {
                 
                 vector < int > path1 ; 
                 pair<int, int> cur = {i, 1};
                 while(cur.first != -1) {
                     path1.push_back(cur.first) ; 
                     cur = par[cur.first][cur.second] ; 
                 }
                 std::reverse(path1.begin(), path1.end());
                 
                 vector < int > path2 ;
                 cur = {i, 2};
                 while(cur.first != -1) {
                     path2.push_back(cur.first) ; 
                     cur = par[cur.first][cur.second] ; 
                 }
                 
                
                 vector<int> path = path1;
                 for (int j = 1; j < (int)path2.size(); ++j) {
                     path.push_back(path2[j]);
                 }
                 
                 cout << mn <<"\n" ; 
                 for (auto nd : path) cout<<nd<<" ";
                 cout<<"\n" ; 
                 return ;
                 
             }
    }
    
   
}







