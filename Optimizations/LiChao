/*
   Basic Idea of CHT  (Convex hull trick)
         considering lines  , delting uncessary segments
         the remaining part is the upper or lower part of convex hull 
         so it's like sine wave >> we can do ternary search on it 

*/
//CHT support add online only
// Set IS_MAX = true for maximum queries, false for minimum queries
template<bool IS_MAX = true>
struct CHT {
    struct Line {
        mutable long long k, m, p;
        int id; // Added ID to uniquely track lines if needed

        bool operator<(const Line& o) const { return IS_MAX ? k < o.k : k > o.k; }
        bool operator<(long long x) const { return p < x; }

        // Custom tie-breaker logic: return true if 'this' is preferred over 'o'
        bool prefer_over(const Line& o) const {
            // Fill your own operator/comparison here
            // Example: return id < o.id; 
            return false;
        }
    };
    
    struct Container : multiset<Line, less<>> {
        static const long long inf = LLONG_MAX;
        long long div(long long a, long long b) { return a / b - ((a ^ b) < 0 && a % b); }
        
        bool isect(iterator x, iterator y) {
            if (y == end()) { x->p = inf; return false; }
            if (x->k == y->k) x->p = (IS_MAX ? x->m > y->m : x->m < y->m) ? inf : -inf;
            else x->p = div(y->m - x->m, x->k - y->k);
            return x->p >= y->p;
        }
        
        void add(long long k, long long m, int id) {
            auto z = insert({k, m, 0, id}), y = z++, x = y;
            while (isect(y, z)) z = erase(z);
            if (x != begin() && isect(--x, y)) isect(x, y = erase(y));
            while ((y = x) != begin() && (--x)->p >= y->p) isect(x, erase(y));
        }
        
        pair<long long, Line> query(long long x) {
            auto it = lower_bound(x);
            auto best = it;
            long long best_val = it->k * x + it->m;
            
            // At exact intersection boundaries, two adjacent lines can have identical values
            if (it != begin()) {
                auto prv = prev(it);
                long long prv_val = prv->k * x + prv->m;
                if (prv_val == best_val) {
                    if (prv->prefer_over(*best)) {
                        best = prv;
                    }
                }
            }
            return {best_val, *best};
        }
    } container;

    void add(long long k, long long m, int id = -1) { container.add(k, m, id); }
    pair<long long, Line> query(long long x) { return container.query(x); }
};
