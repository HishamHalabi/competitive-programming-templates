template<typename T, bool IS_MIN = true>
struct CHT {
    struct Line {
        mutable T k, b, p; int id;
        T eval(T x) const { return k * x + b; }
        bool operator<(const Line& o) const { return k < o.k; }
        bool operator<(T x) const { return p < x; }
    };
    
    typedef typename multiset<Line, less<>>::iterator iter;
    multiset<Line, less<>> hull;
    T inf = is_integral_v<T> ? numeric_limits<T>::max() : 1e18;

    T div(T a, T b) { 
        if constexpr (is_integral_v<T>) return a / b - (((a ^ b) < 0 && a % b) != 0);
        return a / b; 
    }
    
    bool is_better(const Line& nw, const Line& curr, T x) {
        if (curr.id == -1) return true;
        T v1 = nw.eval(x), v2 = curr.eval(x), eps = is_integral_v<T> ? 0 : 1e-11;
        return abs(v1 - v2) > eps ? (IS_MIN ? (v1 < v2) : (v1 > v2)) : nw.id  <   curr.id;
    }

    bool intersect(iter x, iter y) {
        if (y == hull.end()) return x->p = inf, 0;
        if (x->k == y->k) x->p = (IS_MIN ? x->b > y->b : x->b < y->b) ? inf : -inf;
        else x->p = div(y->b - x->b, x->k - y->k);
        return x->p >= y->p;
    }

    void add(T k, T b, int id) {
        auto z = hull.insert({k, b, 0, id}), y = z++, x = y;
        while (intersect(y, z)) z = hull.erase(z);
        if (x != hull.begin() && intersect(--x, y)) intersect(x, y = hull.erase(y));
        while ((y = x) != hull.begin() && (--x)->p >= y->p) intersect(x, hull.erase(y));
    }

    Line get(T x) {
        if (hull.empty()) return {0, 0, 0, -1};
        auto it = hull.lower_bound(x);
        Line bst = *it;
        for (int i = 0; i < 2 && it != hull.end(); ++i, ++it) 
            if (is_better(*it, bst, x)) bst = *it;
        return bst;
    }
};
