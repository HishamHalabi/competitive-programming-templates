template<typename T, bool IS_MIN_QUERY = true> 
struct LC {
    struct Line {
        T k, b; int id;
        T eval(T x) const { return k * x + b; }
    };

    struct Node { Line line = {0, 0, -1}; int lc = 0, rc = 0; };
    
    T L, R; int root;
    vector<Node> tree; vector<bool> del;

    LC(T L, T R) : L(L), R(R) {
        tree.push_back({}); root = create();
    }
    
    int create() { tree.push_back({{0, 0, -1}, 0, 0}); return tree.size() - 1; }

    bool is_better(const Line& nw, const Line& curr, T x) {
        if (curr.id == -1) return true;
        T v1 = nw.eval(x), v2 = curr.eval(x), eps = is_integral_v<T> ? 0 : 1e-11;
        if (abs(v1 - v2) > eps) return IS_MIN_QUERY ? (v1 < v2) : (v1 > v2);
        return nw.id < curr.id; // Match your tie-breaker: prefer smaller line index
    }
    
    void insert(int u, T l, T r, Line nw) {
        if (nw.id < (int)del.size() && del[nw.id]) return;
        if (tree[u].line.id != -1 && tree[u].line.id < (int)del.size() && del[tree[u].line.id]) { 
            tree[u].line = nw; 
            return; 
        }
        T mid = l + (r - l) / 2;
        bool sl = is_better(nw, tree[u].line, l), sm = is_better(nw, tree[u].line, mid);
        if (sm) swap(tree[u].line, nw);
        if (r - l <= (is_integral_v<T> ? 0 : 1e-11)) return;
        if (sl != sm) {
            if (!tree[u].lc) tree[u].lc = create();
            insert(tree[u].lc, l, mid, nw);
        } else {
            if (!tree[u].rc) tree[u].rc = create();
            insert(tree[u].rc, mid + (is_integral_v<T> ? 1 : 0), r, nw);
        }
    }
    
    int add(T k, T b , int id) { 
        if (id >= (int)del.size()) del.resize(id + 1, false); // Fix: Safe vector bounds allocation
        insert(root, L, R, {k, b, id}); 
        return id; 
    }
    
    void remove(int id) { if (id >= 0 && id < (int)del.size()) del[id] = true; }
    
    void upd(Line& bst, const Line& cand, T x) {
        if (cand.id != -1 && (cand.id >= (int)del.size() || !del[cand.id]) && (bst.id == -1 || is_better(cand, bst, x))) bst = cand;
    }
    
    Line query(int u, T l, T r, T x) {
        if (!u) return {0, 0, -1};
        Line bst = {0, 0, -1}; upd(bst, tree[u].line, x);
        if (r - l <= (is_integral_v<T> ? 0 : 1e-11)) return bst;
        T mid = l + (r - l) / 2;
        upd(bst, x <= mid ? query(tree[u].lc, l, mid, x) : query(tree[u].rc, mid + (is_integral_v<T> ? 1 : 0), r, x), x);
        return bst;
    }
    
    Line get(T x) { return query(root, L, R, x); }
};

