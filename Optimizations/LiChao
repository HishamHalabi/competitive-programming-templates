int main() {
    // 1. Min CHT Example
    CHT<false> min_cht; 
    min_cht.add(2, 3); // y = 2x + 3
    min_cht.add(-1, 10); // y = -x + 10
    // query(5) -> min(13, 5) = 5
    
    // 2. Max LiChao Tree with deletion Example
    LiChao<true> max_lc;
    int l1 = max_lc.add(2, 5);  // y = 2x + 5
    int l2 = max_lc.add(-1, 20); // y = -x + 20
    
    cout << max_lc.query(4) << "\n"; // Output: 16 (from l2)
    max_lc.del(l2);
    cout << max_lc.query(4) << "\n"; // Output: 13 (reverts back to l1 safely)
}




















// Set IS_MAX = true for maximum queries, false for minimum queries
template<bool IS_MAX = true, long long MIN_X = -1000000000, long long MAX_X = 1000000000>
struct LiChao {
    static const long long INF = 4e18;
    struct Line {
        long long k, m; int id;
        long long eval(long long x) const { return k * x + m; }

        // Custom tie-breaker logic: return true if 'this' is preferred over 'o'
        bool prefer_over(const Line& o) const {
            // Fill your own operator/comparison here
            // Example: return id < o.id;
            return false;
        }
    };

    struct Node {
        Line line = {0, IS_MAX ? -INF : INF, -1};
        int l = -1, r = -1;
    };

    vector<Node> tree;
    vector<bool> deleted;

    LiChao() { tree.push_back(Node()); }

    bool better(Line a, Line b, long long x) {
        if (b.id != -1 && deleted[b.id]) return true;
        if (a.id != -1 && deleted[a.id]) return false;
        return IS_MAX ? a.eval(x) > b.eval(x) : a.eval(x) < b.eval(x);
    }

    void add_line(int idx, long long l, long long r, Line nw) {
        long long mid = l + (r - l) / 2;
        bool b_mid = better(nw, tree[idx].line, mid);
        bool b_l = better(nw, tree[idx].line, l);
        if (b_mid) swap(tree[idx].line, nw);
        if (l == r || nw.id == -1 || (nw.id != -1 && deleted[nw.id])) return;
        if (b_l != b_mid) {
            if (tree[idx].l == -1) { tree[idx].l = tree.size(); tree.push_back(Node()); }
            add_line(tree[idx].l, l, mid, nw);
        } else {
            if (tree[idx].r == -1) { tree[idx].r = tree.size(); tree.push_back(Node()); }
            add_line(tree[idx].r, mid + 1, r, nw);
        }
    }

    // Helper to evaluate and cleanly resolve line comparison priorities
    pair<long long, Line> merge_res(pair<long long, Line> a, pair<long long, Line> b) {
        if (a.second.id == -1) return b;
        if (b.second.id == -1) return a;
        if (a.first != b.first) {
            if (IS_MAX) return a.first > b.first ? a : b;
            else return a.first < b.first ? a : b;
        }
        return a.second.prefer_over(b.second) ? a : b;
    }

    pair<long long, Line> query(int idx, long long l, long long r, long long x) {
        if (idx == -1) return {IS_MAX ? -INF : INF, {0, 0, -1}};
        
        pair<long long, Line> cur = {IS_MAX ? -INF : INF, {0, 0, -1}};
        if (tree[idx].line.id != -1 && !deleted[tree[idx].line.id]) {
            cur = {tree[idx].line.eval(x), tree[idx].line};
        }
        
        if (l == r) return cur;
        long long mid = l + (r - l) / 2;
        pair<long long, Line> sub;
        if (x <= mid) sub = query(tree[idx].l, l, mid, x);
        else sub = query(tree[idx].r, mid + 1, r, x);
        
        return merge_res(cur, sub);
    }

    // Public API
    int add(long long k, long long m) {
        int id = deleted.size(); deleted.push_back(false);
        add_line(0, MIN_X, MAX_X, {k, m, id});
        return id;
    }
    void del(int id) { if (id >= 0 && id < deleted.size()) deleted[id] = true; }
    pair<long long, Line> query(long long x) { return query(0, MIN_X, MAX_X, x); }
};

int main() {
    // Example: Min CHT
    CHT<false> min_cht; 
    min_cht.add(2, 3, 101);   // y = 2x + 3,  id = 101
    min_cht.add(-1, 10, 102); // y = -x + 10, id = 102
    
    auto [val1, line1] = min_cht.query(5);
    cout << "CHT Val: " << val1 << ", Line ID: " << line1.id << "\n"; 

    // Example: Max LiChao
    LiChao<true> max_lc;
    max_lc.add(2, 5);  
    max_lc.add(-1, 20); 
    
    auto [val2, line2] = max_lc.query(4);
    cout << "LiChao Val: " << val2 << ", Line ID: " << line2.id << "\n";
}

