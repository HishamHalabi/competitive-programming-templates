template<bool IS_MAX = true>
struct CHT {
    struct Line {
        mutable long double k, m, p;
        int id;

        bool operator<(const Line& o) const { return IS_MAX ? k < o.k : k > o.k; }
        bool operator<(long double x) const { return p < x; }

        bool prefer_over(const Line& o) const {
            return false; // Implement custom tie-breaker if values match
        }
    };
    
    struct Container : multiset<Line, less<>> {
        // Use floating-point infinity
        static constexpr long double inf = INFINITY;
        
        bool isect(iterator x, iterator y) {
            if (y == end()) { x->p = inf; return false; }
            if (x->k == y->k) x->p = (IS_MAX ? x->m > y->m : x->m < y->m) ? inf : -inf;
            else x->p = (y->m - x->m) / (x->k - y->k); // Direct floating-point division
            return x->p >= y->p;
        }
        
        void add(long double k, long double m, int id) {
            auto z = insert({k, m, 0, id}), y = z++, x = y;
            while (isect(y, z)) z = erase(z);
            if (x != begin() && isect(--x, y)) isect(x, y = erase(y));
            while ((y = x) != begin() && (--x)->p >= y->p) isect(x, erase(y));
        }
        
        pair<long double, Line> query(long double x) {
            auto it = lower_bound(x);
            auto best = it;
            long double best_val = it->k * x + it->m;
            
            if (it != begin()) {
                auto prv = prev(it);
                long double prv_val = prv->k * x + prv->m;
                
                // Using a small epsilon value to check equality due to floating-point precision issues
                if (abs(prv_val - best_val) < 1e-11) {
                    if (prv->prefer_over(*best)) {
                        best = prv;
                    }
                }
            }
            return {best_val, *best};
        }
    } container;

    void add(long double k, long double m, int id = -1) { container.add(k, m, id); }
    pair<long double, Line> query(long double x) { return container.query(x); }
};

