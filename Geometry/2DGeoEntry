// --- Basic Vector Mathematics (PT Custom Overloads) ---

// Returns the geometric quadrant location (1 through 4) of a point vector
int quarter(PT p) {
   if (sgn(p.x) == 1) {
             return sgn(p.y) > 0 ? 1: 4;
   }
   return sgn(p.y) > 0 ? 2:3;
}

// magin^2  || |V|^2 -> Returns the magnitude squared of the point representation
T sq(PT p) {
    return p.x*p.x + p.y*p.y;
}

// |v|   * |w| * cos(O) -> Returns the scalar dot product of vectors v and w
// cos(x) =  cos(360  - x)
inline double dot(PT a, PT b) { return a.x * b.x + a.y * b.y; }

// |v|   * |w| * sin(O) -> Returns the cross product scalar value of vectors v and w
// sin(x) =  -sin(360  - x)  >> sin(O)    = sin(180 - O)
inline double cross(PT a, PT b) { return a.x * b.y - a.y * b.x; }

// Returns the squared distance calculation between PT vector positions a and b
inline double dist2(PT a, PT b) { return dot(a - b, a - b); }

// Returns the Euclidean linear distance calculation between two PT points
inline double dist(PT a, PT b) { return sqrt(dot(a - b, a - b)); }

// Returns the scalar cross product of vectors (b-a) and (c-a)
inline double cross2(PT a, PT b, PT c) { return cross(b - a, c - a); }

// Returns the sign orientation direction sequence metric for custom points a, b, and c
inline int orientation(PT a, PT b, PT c) { return sign(cross(b - a, c - a)); }

// Returns true if the cross product between vectors v and w resolves safely to zero
bool isPrep(PT v, PT w) {
      return sgn(cross(v, w)) == 0;
}

// Returns a point inverted across coordinate axes to render a standard perpendicular projection vector
PT prep(PT p) {
    return {-p.y, p.x};
}

// Returns a PT vector structure rotated exactly 90 degrees counter-clockwise
PT perp(PT a) { return PT(-a.y, a.x); }

// Returns a PT vector structure rotated exactly 90 degrees counter-clockwise
PT rotateccw90(PT a) { return PT(-a.y, a.x); }

// Returns a PT vector structure rotated exactly 90 degrees clockwise
PT rotatecw90(PT a) { return PT(a.y, -a.x); }

// Returns a PT point position vector rotated counter-clockwise by an arbitrary radian measure t
PT rotateccw(PT a, double t) { return PT(a.x * cos(t) - a.y * sin(t), a.x * sin(t) + a.y * cos(t)); }

// Returns a PT point position vector rotated clockwise by an arbitrary radian measure t
PT rotatecw(PT a, double t) { return PT(a.x * cos(t) + a.y * sin(t), -a.x * sin(t) + a.y * cos(t)); }


// --- Geometric Matrix Transformations ---

// Translates a point point by adding a vector displacement offset
PT translate(PT v, PT w) {
   return {v.x + w.x, v.y + w.y};
}

// Scales point values relative to standard reference scaling multi-factors
PT scale(PT v, T sc) {
    return {v.x*sc, v.y*sc};
}

// Rotates a point around an arbitrary pivot point c by a radian value angle a
PT rot(PT p, PT c, ld a) {
    PT v = p - c;
    PT rotate = {cos(a), sin(a)};
    return c + PT(v.x * rotate.x - v.y * rotate.y, v.x * rotate.y + v.y * rotate.x);
}

// Performs a standard linear scale/rotate map transformation tracking mapping pairs p->fp and q->fq
PT linearTransfo(PT p, PT q, PT r, PT fp, PT fq) {
    PT num = PT((r-p).x * (fq-fp).x - (r-p).y * (fq-fp).y, (r-p).x * (fq-fp).y + (r-p).y * (fq-fp).x);
    double den_norm2 = (q-p).norm2();
    PT div = PT((num.x * (q-p).x + num.y * (q-p).y) / den_norm2, (num.y * (q-p).x - num.x * (q-p).y) / den_norm2);
    return fp + div;
}


// --- Angle Processing & Orientation Metrics ---

// ab   ,   ac   >>   cross btw them -> Returns cross product orientation matching cross(b-a, c-a)
T orient(PT a, PT b, PT c) {
        return cross(b-a, c-a);
}

// get the angle from 0  to pi >> postive angle || one of the two possible
T angle(PT v, PT w) {
    T a1 = atan2(w.y, w.x);
    T a2 = atan2(v.y, v.x);
    T ang = fabs(a1 -a2);
    return ang = min(ang, 2*PI - ang);
}

// u need angle from ba  to ca   >> dot gives u 2 choices >> based on direction pick the right one -> returns postive angle   , neg O  = 360 - O  >> [0....2*pi]
T orientedAngle(PT a, PT b, PT c) {
   T ang = angle(b-a, c-a);

   if(sgn(orient(a, b, c)) == 1) {
              return ang;
   }
   return 2*PI - ang;
}

// same as above but it's like giving -O here and 360-O above -> exact angle counter-clockwise signed deflection accumulation
T angleTravelled(PT a, PT b, PT c) { //exact angle +=[0...pi]
    T ampli = angle(b - a, c - a);
    if(orient(a, b, c) > 0) return ampli;
    else return -ampli;
}

// Returns absolute orientation angle parsed from a standard horizontal coordinate baseline vector axis
T angleFromX(PT p1) { //exact
    PT org(0, 0);
    PT p2(3, 0);
    T angle = orientedAngle(org, p2, p1);
    if (fabs(angle - 2*PI) <= EPS) angle = 0;
    return angle;
}

// Returns the internal radian dimension bounded by vector structures a and b
double get_angle(PT a, PT b) {
    double costheta = dot(a, b) / a.norm() / b.norm();
    return acos(max((double)-1.0, min((double)1.0, costheta)));
}

// if p is in angle from ba to   ca -> Returns whether point position matches interior angle boundaries
bool inAngle(PT a, PT b, PT c, PT p) {
    T abc = orient(a, b, c);
    T abp = orient(a, b, p), acp = orient(a, c, p);
    if(abc < 0) swap(abp, acp);
    if (abp >= 0 and acp <= 0) {
           return true;
    }
    return false;
}

// does point p lie in angle <bac -> Returns whether point matches interior angular bounds for custom points
bool is_point_in_angle(PT b, PT a, PT c, PT p) {
    assert(orientation(a, b, c) != 0);
    if (orientation(a, c, b) < 0) swap(b, c);
    return orientation(a, c, p) >= 0 && orientation(a, b, p) <= 0;
}


// --- Polar Sorting Infrastructure ---

// true if in blue half -> Helper boundary function parsing polar points split into upper half-planes
bool half(PT p) {
    assert(p.x != 0 || p.y != 0); // the argument of (0,0) is undefined
    return p.y > 0.0 || (p.y == 0.0 && p.x < 0.0);
}

// sort points according how is smaller angle from x axis
void polarSort(vector<PT> &v) {
    sort(v.begin(), v.end(), [](PT v, PT w) {
         return make_tuple(half(v), 0.0) <
          make_tuple(half(w), cross(v,w));
    });
}

// sort points in counterclockwise order using tuple chaining loops
void polar_sort(vector<PT> &v) {
    sort(v.begin(), v.end(), [](PT a, PT b) {
        return make_tuple(half(a), 0.0, a.norm2()) < make_tuple(half(b), cross(a, b), b.norm2());
    });
}

// sort points in counterclockwise with respect to an arbitrary point origin reference o
void polar_sort(vector<PT> &v, PT o) {
    sort(v.begin(), v.end(), [&](PT a, PT b) {
        return make_tuple(half(a - o), 0.0, (a - o).norm2()) < make_tuple(half(b - o), cross(a - o, b - o), (b - o).norm2());
    });
}


// --- Linear Coordinate Geometry Structure Wrappers ---

/*
  line >> from point p  to point q
    ----------------------------------
    ax +  by   =  c
    vector on line from left (a,b)
    vector of line  (b,-a)

    (a,b) dot (x,y) = c = ax+by  even point not on line
    (b,  -a) cross (x,y) = c    = ax+by  >> even for point not on line
    ------------------------------------
    positve side is wacking from the end of line to left
    negative is to the right

    to check
     ax+by  - real c > 0 pos , <0 neg ,
     fun fact abs((ax+ by - c) / |v|)  distance from the point to the line

     multipying vector of line by another vector   = ax+by  for the the line containg point moving from line by this vector

     for same line  a,b,c are unique if a are same i.e make a =1 ,divide b/a ,c/a now this unique for this line
     for parrallel a,b are unique with same method as above
     but note using b as unique   ,  b,c    >> this will not be valid when a = 0   >> i think we can make a = EPS or -EPS
     but anyway for integer cordinates  >>a ,b,c are int and u can divide by gc and make a pos and (a,b,c) unique line  , (a,b)  un parrallel
    ------------------------------------
*/
struct line {
    PT v; T c;
    PT a, b; // goes through points a and b
    //line form: direction vec [cross] (x, y) = c

    line() {}
    line(PT v, T c) : v(v), c(c) {}

    // from equation ax+by = c
    line(T _a, T _b, T _c) {
        v = PT(-_b, _a);
        c = _c;
    }

    //line from two points
    line(PT p, PT q) {
        v = q - p;
        c = cross(v, p);
    }

    // extract any two points from this line
    pair<PT, PT> get_points() {
        PT p, q; double _a = -v.y, _b = v.x; // ax + by = c
        if (sign(_a) == 0) {
            p = PT(0, c / _b);
            q = PT(1, c / _b);
        }
        else if (sign(_b) == 0) {
            p = PT(c / _a, 0);
            q = PT(c / _a, 1);
        }
        else {
            p = PT(0, c / _b);
            q = PT(1, (c - _a) / _b);
        }
        return {p, q};
    }

    // Returns standard formula coefficients array {a, b, c} matching ax + by + c = 0
    array<double, 3> get_abc() {
        double _a = -v.y, _b = v.x;
        return {_a, _b, -c};
    }

    // Returns structural cross displacement distance of a target point evaluated against the line vector
    T side(PT p) { return cross(v, p) - c; }

    // Returns standard linear scalar offset tracking Euclidean perpendicular distance metrics
    ld dist(PT p) { return abs(side(p)) / v.norm(); }

    // Returns non-square rooted processing distance measurements to bypass precision degradation
    double sqDist(PT p) { return side(p)*side(p) / (T)sq(v); }

    // getting line that's perp with me and pass by point p
    line prepThrought(PT p) {
        return {p, p + prep(v)};
    }

    // line that is perpendicular to this and goes through point p
    line perpendicular_through(PT p) { return {p, p + prep(v)}; }

    // which point appears in line first
    bool cmpProj(PT p, PT q) {
        return dot(v, p) < dot(v, q);
    }

    // compare two points by their orthogonal projection on this line
    // a projection point comes before another if it comes first according to vector v
    bool cmp_by_projection(PT p, PT q) { return dot(v, p) < dot(v, q); }

    // translaing line by vector t >> the idea that v of new line is same , we only need the new c
    line translate(PT t) {
        return {v, c + cross(v, t)};
    }

    // Shifts the structural linear ray boundary toward its left plane by explicit scalar distance measurements
    line shiftLeft(T dist) {
        return {v, c + dist*v.norm()};
    }

    // Shifts the custom PT linear bounding trajectory leftwards relative to orientation vectors
    line shift_left(double d) {
        PT z = PT(-v.y, v.x).truncate(d); // uses perp-like properties mapping from structure v
        return line(a + z, b + z);
    }

    // Returns the closest orthogonal projection coordinate mapping of point p directly on the line
    PT proj(PT p) {
        return p - prep(v)*side(p)/sq(v);
    }

    // Returns mirrored reflection mappings mirror translating an external point across the linear axis
    PT refl(PT p) {
        return p - prep(v) * (T)2.0 * side(p)/sq(v);
    }
};


// --- Linear Intersections & Relational Properties ---

// Parses cross boundaries returning unique line intercept cross coordinates into output parameter out
bool inter(line l1, line l2, PT &out) {
        T d = cross(l1.v, l2.v);
        if (d == 0) return false;
        out = (l2.v*l1.c - l1.v*l2.c) / d; // requires floating-point coordinates
        return true;
}

// line that divide angle btw 2 lines equaly >> line divide in same direction is interior =1  , else  = 0 or vice i dont rem
line bisector(line l1, line l2, bool interior) {
    T cr = cross(l1.v, l2.v);

    if (fabs(cr) < EPS)
        throw runtime_error("Parallel lines");

    T n1 = l1.v.norm();
    T n2 = l2.v.norm();

    T s = interior ? 1 : -1;

    PT A = l2.v / n2 + (l1.v / n1) * s;

    T C = l2.c / n2 + (l1.c / n1) * s;

    return line(A, C);
}

// find a point from a through b with distance d
PT point_along_line(PT a, PT b, double d) {
    assert(a != b);
    return a + (((b - a) / (b - a).norm()) * d);
}

// projection point c onto line through a and b assuming a != b
PT project_from_point_to_line(PT a, PT b, PT c) {
    return a + (b - a) * dot(c - a, b - a) / (b - a).norm2();
}

// reflection point c onto line through a and b assuming a != b
PT reflection_from_point_to_line(PT a, PT b, PT c) {
    PT p = project_from_point_to_line(a, b, c);
    return p + p - c;
}

// minimum distance from point c to line through a and b
double dist_from_point_to_line(PT a, PT b, PT c) {
    return fabs(cross(b - a, c - a) / (b - a).norm());
}

// 0 if not parallel, 1 if parallel, 2 if collinear
int is_parallel(PT a, PT b, PT c, PT d) {
    double k = fabs(cross(b - a, d - c));
    if (k < eps) {
        if (fabs(cross(a - b, a - c)) < eps && fabs(cross(c - d, c - a)) < eps) return 2;
        else return 1;
    }
    else return 0;
}

// check if two lines are same
bool are_lines_same(PT a, PT b, PT c, PT d) {
    if (fabs(cross(a - c, c - d)) < eps && fabs(cross(b - c, c - d)) < eps) return true;
    return false;
}

// bisector vector of <abc
PT angle_bisector(PT &a, PT &b, PT &c) {
    PT p = a - b, q = c - b;
    return p + q * sqrt(dot(p, p) / dot(q, q));
}

// 1 if point is ccw to the line, 2 if point is cw to the line, 3 if point is on the line
int point_line_relation(PT a, PT b, PT p) {
    int c = sign(cross(p - a, b - a));
    if (c < 0) return 1;
    if (c > 0) return 2;
    return 3;
}

// intersection point between ab and cd assuming unique intersection exists
bool line_line_intersection(PT a, PT b, PT c, PT d, PT &ans) {
    double a1 = a.y - b.y, b1 = b.x - a.x, c1 = cross(a, b);
    double a2 = c.y - d.y, b2 = d.x - c.x, c2 = cross(c, d);
    double det = a1 * b2 - a2 * b1;
    if (det == 0) return 0;
    ans = PT((b1 * c2 - b2 * c1) / det, (c1 * a2 - a1 * c2) / det);
    return 1;
}


// --- Segments Processing Layers ---

// Returns true if point p is positioned strictly bounded within a disk diametrically framed by points a and b
bool inDisk(PT a, PT b, PT p) {
    return dot(a-p, b-p) <= EPS;
}

// Returns true if point c lies exactly on the line segment connecting points a and b
bool onSegment(PT a, PT b, PT c) {
    return orient(a, b, c) == 0 && inDisk(a, b, c);
}

// get the unique intersection btw 2 lines
bool properInter(PT a, PT b, PT c, PT d, PT &out) {
    T oa = orient(c, d, a),
        ob = orient(c, d, b),
        oc = orient(a, b, c),
        od = orient(a, b, d);
    // Proper intersection exists iff opposite signs
    if (sgn(oa)*sgn(ob) < 0 && sgn(oc)*sgn(od) < 0) {
        out = (a*ob - b*oa) / (ob-oa);
        return true;
    }
    return false;
}

// as two ss may have range of intersections
set<pair<ld, ld>> inters(PT a, PT b, PT c, PT d) {
    set<pair<ld, ld>> s;
    PT out;
    if(a == c || a == d) {
        s.insert(make_pair(a.x, a.y));
    }
    if(b == c || b == d) {
        s.insert(make_pair(b.x, b.y));
    }
    if(s.size()) return s;

    if (properInter(a, b, c, d, out)) return {make_pair(out.x, out.y)};
    if (onSegment(c, d, a)) s.insert(make_pair(a.x, a.y));
    if (onSegment(c, d, b)) s.insert(make_pair(b.x, b.y));
    if (onSegment(a, b, c)) s.insert(make_pair(c.x, c.y));
    if (onSegment(a, b, d)) s.insert(make_pair(d.x, d.y));

    return s;
}

// Returns shortest scalar Euclidean distance tracking distance offsets from point p to target segment ab
ld segPoint(PT a, PT b, PT p) {
    if (a != b) {
        line l(a, b);
        if (l.cmpProj(a, p) && l.cmpProj(p, b)) // if closest to projection
            return l.dist(p); // output distance to line
    }
    return min(dist(p, a), dist(p, b)); // otherwise distance to A or B
}

// distance from seg to seg [enough to pick one of endpoints
ld segSeg(PT a, PT b, PT c, PT d) {
    PT dummy;
    if (properInter(a, b, c, d, dummy))
        return 0;
    return min({segPoint(a, b, c), segPoint(a, b, d),
                segPoint(c, d, a), segPoint(c, d, b)});
}

// returns true if point p is on line segment ab using custom PT definitions
bool is_point_on_seg(PT a, PT b, PT p) {
    if (fabs(cross(p - b, a - b)) < eps) {
        if (p.x < min(a.x, b.x) - eps || p.x > max(a.x, b.x) + eps) return false;
        if (p.y < min(a.y, b.y) - eps || p.y > max(a.y, b.y) + eps) return false;
        return true;
    }
    return false;
}

// minimum distance point from point c to segment ab that lies on segment ab
PT project_from_point_to_seg(PT a, PT b, PT c) {
    double r = dist2(a, b);
    if (sign(r) == 0) return a;
    r = dot(c - a, b - a) / r;
    if (r < 0) return a;
    if (r > 1) return b;
    return a + (b - a) * r;
}

// minimum distance from point c to segment ab
double dist_from_point_to_seg(PT a, PT b, PT c) {
    return dist(c, project_from_point_to_seg(a, b, c));
}

// intersection point between segment ab and segment cd assuming unique intersection exists
bool seg_seg_intersection(PT a, PT b, PT c, PT d, PT &ans) {
    double oa = cross2(c, d, a), ob = cross2(c, d, b);
    double oc = cross2(a, b, c), od = cross2(a, b, d);
    if (oa * ob < 0 && oc * od < 0) {
        ans = (a * ob - b * oa) / (ob - oa);
        return 1;
    }
    else return 0;
}

// intersection point between segment ab and segment cd assuming unique intersection may not exists
// se.size()==0 means no intersection, 1 means one intersection, 2 means range intersection
set<PT> seg_seg_intersection_inside(PT a, PT b, PT c, PT d) {
    PT ans;
    if (seg_seg_intersection(a, b, c, d, ans)) return {ans};
    set<PT> se;
    if (is_point_on_seg(c, d, a)) se.insert(a);
    if (is_point_on_seg(c, d, b)) se.insert(b);
    if (is_point_on_seg(a, b, c)) se.insert(c);
    if (is_point_on_seg(a, b, d)) se.insert(d);
    return se;
}

// intersection between segment ab and line cd -> 0 if do not intersect, 1 if proper intersect, 2 if segment intersect
int seg_line_relation(PT a, PT b, PT c, PT d) {
    double p = cross2(c, d, a);
    double q = cross2(c, d, b);
    if (sign(p) == 0 && sign(q) == 0) return 2;
    else if (p * q < 0) return 1;
    else return 0;
}

// intersection between segment ab and line cd assuming unique intersection exists
bool seg_line_intersection(PT a, PT b, PT c, PT d, PT &ans) {
    bool k = seg_line_relation(a, b, c, d);
    assert(k != 2);
    if (k) line_line_intersection(a, b, c, d, ans);
    return k;
}

// minimum distance from segment ab to segment cd using custom PT frameworks
double dist_from_seg_to_seg(PT a, PT b, PT c, PT d) {
    PT dummy;
    if (seg_seg_intersection(a, b, c, d, dummy)) return 0.0;
    else return min({dist_from_point_to_seg(a, b, c), dist_from_point_to_seg(a, b, d),
        dist_from_point_to_seg(c, d, a), dist_from_point_to_seg(c, d, b)});
}


// --- Ray Operations Strategy Layer ---

// Forward declaration of above
bool above(PT a, PT p);

// check if [PQ] crosses ray from A -> read it from book , but so far it checks intersection from one side of line  (making it always above)
bool crossesRay(PT a, PT p, PT q) {
    return (above(a, q) - above(a, p)) * orient(a, p, q) > 0;
}

// check if point projection is on ray using explicit coordinate parsing bounds
bool pointOnRay(ld X, ld Y, ld a, ld b, ld c, ld d) {
    PT p(X, Y), A(a, b), B(c, d);
    return dot(p-A, B-A) >= -EPS;
}

// Returns Euclidean vector distance linking an external coordinate to a localized infinite ray sequence
T pointRay(ld X, ld Y, ld a, ld b, ld c, ld d) {
     line l(PT(a, b), PT(c, d));
     PT p(X, Y);
     PT proj = l.proj(p);

     bool out =
        ((c != a && (proj.x - a) * (c - a) < -EPS)) ||
        ((d != b && (proj.y - b) * (d - b) < -EPS));
     if (out) {
           ld dx = (X - a), dy = (Y - b);
           ld dist_val = sqrt(dx * dx + dy * dy);
           return dist_val;
     } else return l.dist(p);
}

// Returns true if a point object maps inside active directional ray sequence limits
bool pointOnRay(PT p, PT a, PT b) {
    return dot(p-a, b-a) >= -EPS;
}

// Returns true if ray configurations map flat along identical underlying collinear tracking axes
bool collinearRays(PT a, PT b, PT c, PT d) {
    return fabsl(orient(a, b, c)) < EPS &&
           fabsl(orient(a, b, d)) < EPS;
}

// Returns standard tracking distance metrics validating clearances separating ray trajectories
ld rayRay(PT a, PT b, PT c, PT d) {
    line l1(a, b), l2(c, d);

    // parallel
    if(fabsl(cross(l1.v, l2.v)) < EPS) {

        // different lines
        if(!collinearRays(a, b, c, d))
            return min(pointRay(c.x, c.y, a.x, a.y, b.x, b.y),
                       pointRay(a.x, a.y, c.x, c.y, d.x, d.y));

        // same supporting line
        if(pointOnRay(c, a, b) || pointOnRay(a, c, d))
            return 0;

        return min(dist(a, c), dist(a, d));
    }

    // non-parallel
    PT p;
    inter(l1, l2, p);

    if(pointOnRay(p, a, b) && pointOnRay(p, c, d))
        return 0;

    return min(pointRay(c.x, c.y, a.x, a.y, b.x, b.y),
               pointRay(a.x, a.y, c.x, c.y, d.x, d.y));
}

// minimum distance from point c to ray (starting point a and direction vector b)
double dist_from_point_to_ray(PT a, PT b, PT c) {
    b = a + b;
    double r = dot(c - a, b - a);
    if (r < 0.0) return dist(c, a);
    return dist_from_point_to_line(a, b, c);
}

// starting point as and direction vector ad -> Returns true if ray structures intersect
bool ray_ray_intersection(PT as, PT ad, PT bs, PT bd) {
    double dx = bs.x - as.x, dy = bs.y - as.y;
    double det = bd.x * ad.y - bd.y * ad.x;
    if (fabs(det) < eps) return 0;
    double u = (dy * bd.x - dx * bd.y) / det;
    double v = (dy * ad.x - dx * ad.y) / det;
    if (sign(u) >= 0 && sign(v) >= 0) return 1;
    else return 0;
}

// Returns Euclidean minimum distance parameters splitting separate custom ray configurations
double ray_ray_distance(PT as, PT ad, PT bs, PT bd) {
    if (ray_ray_intersection(as, ad, bs, bd)) return 0.0;
    double ans = dist_from_point_to_ray(as, ad, bs);
    ans = min(ans, dist_from_point_to_ray(bs, bd, as));
    return ans;
}


// --- Polygons Core Processing Layer ---

// Returns geometric area of triangle matching three absolute coordinate corners
ld areaTriangle(PT a, PT b, PT c) {
    return abs(cross(b-a, c-a)) / 2.0;
}

// Returns cross polygon area calculation tracking arbitrary boundary vertices arrays
ld areaPolygon(vector<PT> p) {
    ld area = 0.0;
    for (int i = 0, n = p.size(); i < n; i++) {
        area += cross(p[i], p[(i+1)%n]); // wrap back to 0 if i == n - 1
    }
    return abs(area) / 2.0;
}

// true if in blue half -> Helper mapping configuration validating vertical point sequence stack heights
bool above(PT a, PT p) {
    return p.y >= a.y;
}

// Returns true if point position maps enclosed inside explicit vector polygon boundaries via crossing loops
bool inPolygon(vector<PT> p, PT a, bool strict) {
    int numCrossings = 0;
    for (int i = 0, n = p.size(); i < n; i++) {
        if (onSegment(p[i], p[(i+1)%n], a))
            return !strict;
        numCrossings += crossesRay(a, p[i], p[(i+1)%n]);
    }
    return numCrossings & 1; // inside if odd number of crossings
}

struct star {
    int n; // number of sides of the star
    double r; // radius of the circumcircle
    star(int _n, double _r) {
        n = _n;
        r = _r;
    }
    double area() {
        double theta = PI / n;
        double s = 2 * r * sin(theta);
        double R = 0.5 * s / tan(theta);
        double a = 0.5 * n * s * R;
        double a2 = 0.25 * s * s / tan(1.5 * theta);
        return a - n * a2;
    }
};

// given a list of lengths of the sides of a polygon in counterclockwise order
// returns the maximum area of a non-degenerate polygon that can be formed using those lengths
double get_maximum_polygon_area_for_given_lengths(vector<double> v) {
    if (v.size() < 3) {
        return 0;
    }
    int m = 0;
    double sum = 0;
    for (int i = 0; i < v.size(); i++) {
        if (v[i] > v[m]) {
            m = i;
        }
        sum += v[i];
    }
    if (sign(v[m] - (sum - v[m])) >= 0) {
        return 0; // no non-degenerate polygon can be formed
    }
    double l = v[m] / 2.0, r = 1e9;
    auto get_angle = [](double side, double radius) {
        return 2.0 * asin(side / (2.0 * radius));
    };
    auto get_total_angle = [&](double radius) {
        double ans = 0;
        for (int i = 0; i < v.size(); i++) {
            ans += get_angle(v[i], radius);
        }
        return ans;
    };
    auto get_total_angle_2 = [&](double radius) {
        double ans = 0;
        for (int i = 0; i < v.size(); i++) {
            if (i == m) {
                ans += 2.0 * PI - get_angle(v[i], radius);
            } else {
                ans += get_angle(v[i], radius);
            }
        }
        return ans;
    };
    bool ok = false;
    for (int iter = 0; iter < 100; iter++) {
        double mid = (l + r) / 2.0;
        if (get_total_angle(mid) >= 2.0 * PI) {
            l = mid;
            ok = true;
        } else {
            r = mid;
        }
    }
    double radius = l;
    if (!ok) {
        l = v[m] / 2.0, r = 1e9;
        for (int iter = 0; iter < 100; iter++) {
            double mid = (l + r) / 2.0;
            if (get_total_angle_2(mid) <= 2.0 * PI) {
                l = mid;
            } else {
                r = mid;
            }
        }
        radius = l;
        double ans = 0;
        for (int i = 0; i < v.size(); i++) {
            double angle = get_angle(v[i], radius);
            double area = 0.5 * radius * radius * sin(angle);
            if (i == m) {
                ans -= area;
            } else {
                ans += area;
            }
        }
        return ans;
    }
    double ans = 0;
    for (int i = 0; i < v.size(); i++) {
        double angle = get_angle(v[i], radius);
        ans += 0.5 * radius * radius * sin(angle);
    }
    return ans;
}


// --- Circular Boundary Core Systems ---

struct circle {
    PT p; double r;
    circle() {}
    circle(PT _p, double _r): p(_p), r(_r) {};
    // center (x, y) and radius r
    circle(double x, double y, double _r): p(PT(x, y)), r(_r) {};

    // circumcircle of a triangle -> the three points must be unique
    circle(PT a, PT b, PT c) {
        b = (a + b) * 0.5;
        c = (a + c) * 0.5;
        line_line_intersection(b, b + rotatecw90(a - b), c, c + rotatecw90(a - c), p);
        r = dist(a, p);
    }

    // inscribed circle of a triangle -> pass a bool just to differentiate from circumcircle
    circle(PT a, PT b, PT c, bool t) {
        line u, v;
        double m = atan2(b.y - a.y, b.x - a.x), n = atan2(c.y - a.y, c.x - a.x);
        u.a = a;
        u.b = u.a + (PT(cos((n + m)/2.0), sin((n + m)/2.0)));
        v.a = b;
        m = atan2(a.y - b.y, a.x - b.x), n = atan2(c.y - b.y, c.x - b.x);
        v.b = v.a + (PT(cos((n + m)/2.0), sin((n + m)/2.0)));
        line_line_intersection(u.a, u.b, v.a, v.b, p);
        r = dist_from_point_to_seg(a, b, p);
    }

    bool operator == (circle v) { return p == v.p && sign(r - v.r) == 0; }
    double area() { return PI * r * r; }
    double circumference() { return 2.0 * PI * r; }
};

// 0 if outside, 1 if on circumference, 2 if inside circle
int circle_point_relation(PT p, double r, PT b) {
    double d = dist(p, b);
    if (sign(d - r) < 0) return 2;
    if (sign(d - r) == 0) return 1;
    return 0;
}

// 0 if outside, 1 if on circumference, 2 if inside circle
int circle_line_relation(PT p, double r, PT a, PT b) {
    double d = dist_from_point_to_line(a, b, p);
    if (sign(d - r) < 0) return 2;
    if (sign(d - r) == 0) return 1;
    return 0;
}

// compute intersection of line through points a and b with circle centered at c with radius r > 0
vector<PT> circle_line_intersection(PT c, double r, PT a, PT b) {
    vector<PT> ret;
    b = b - a; a = a - c;
    double A = dot(b, b), B = dot(a, b);
    double C = dot(a, a) - r * r, D = B * B - A * C;
    if (D < -eps) return ret;
    ret.push_back(c + a + b * (-B + sqrt(D + eps)) / A);
    if (D > eps) ret.push_back(c + a + b * (-B - sqrt(D)) / A);
    return ret;
}

// 5 - outside and do not intersect, 4 - intersect outside in one point, 3 - intersect in 2 points, 2 - intersect inside in one point, 1 - inside and do not intersect
int circle_circle_relation(PT a, double r, PT b, double R) {
    double d = dist(a, b);
    if (sign(d - r - R) > 0)  return 5;
    if (sign(d - r - R) == 0) return 4;
    double l = fabs(r - R);
    if (sign(d - r - R) < 0 && sign(d - l) > 0) return 3;
    if (sign(d - l) == 0) return 2;
    if (sign(d - l) < 0) return 1;
    assert(0); return -1;
}

// Returns point array containing calculated path intersection bounds mapping crossed circle bounds
vector<PT> circle_circle_intersection(PT a, double r, PT b, double R) {
    if (a == b && sign(r - R) == 0) return {PT(1e18, 1e18)};
    vector<PT> ret;
    double d = sqrt(dist2(a, b));
    if (d > r + R || d + min(r, R) < max(r, R)) return ret;
    double x = (d * d - R * R + r * r) / (2 * d);
    double y = sqrt(r * r - x * x);
    PT v = (b - a) / d;
    ret.push_back(a + v * x + rotateccw90(v) * y);
    if (y > 0) ret.push_back(a + v * x - rotateccw90(v) * y);
    return ret;
}

// returns two circle c1, c2 through points a, b and of radius r -> 0 if there is no such circle, 1 if one circle, 2 if two circle
int get_circle(PT a, PT b, double r, circle &c1, circle &c2) {
    vector<PT> v = circle_circle_intersection(a, r, b, r);
    int t = v.size();
    if (!t) return 0;
    c1.p = v[0], c1.r = r;
    if (t == 2) c2.p = v[1], c2.r = r;
    return t;
}

