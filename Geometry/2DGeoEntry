// --- Primary Custom Floating Point Utilities ---

// Returns the sign of a floating point value based on the template's EPS check bounds
int sgn(T val) {
   if (val > EPS) return 1;
   if (val < -EPS) return -1;
   return 0;
}

// Returns 1 if positive, -1 if negative, or 0 if within eps boundary limits
int sign(double x) { return (x > eps) - (x < -eps); }

// Returns squared value of a double
double SQ(double x) { return x * x; }

// Converts angles from radian values to degrees
double rad_to_deg(double r) { return (r * 180.0 / PI); }

// Converts angles from degree values to radians
double deg_to_rad(double d) { return (d * PI / 180.0); }

// Rounds a coordinate translation value accurately up or down past float drift limits
int INT(T v) {
  if (v < 0)
       v -= EPS;
  else
     v += EPS;
  return (int)v;
}


// --- Custom PT Struct Definition ---

// https://victorlecomte.com/cp-geo.pdf
struct PT {
    double x, y;
    PT() { x = 0, y = 0; }
    PT(double x, double y) : x(x), y(y) {}
    PT(const PT &p) : x(p.x), y(p.y)    {}
    PT operator + (const PT &a) const { return PT(x + a.x, y + a.y); }
    PT operator - (const PT &a) const { return PT(x - a.x, y - a.y); }
    PT operator * (const double a) const { return PT(x * a, y * a); }
    friend PT operator * (const double &a, const PT &b) { return PT(a * b.x, a * b.y); }
    PT operator / (const double a) const { return PT(x / a, y / a); }
    bool operator == (PT a) const { return sign(a.x - x) == 0 && sign(a.y - y) == 0; }
    bool operator != (PT a) const { return !(*this == a); }
    bool operator < (PT a) const { return sign(a.x - x) == 0 ? y < a.y : x < a.x; }
    bool operator > (PT a) const { return sign(a.x - x) == 0 ? y > a.y : x > a.x; }

    // Returns the standard Euclidean length (norm) of the vector
    double norm() const { return sqrt(x * x + y * y); }

    // Returns the squared Euclidean length of the vector to bypass sqrt precision loss
    double norm2() const { return x * x + y * y; }

    // Returns a vector perpendicular to the current one rotated counter-clockwise
    PT perp() const { return PT(-y, x); }

    // Returns the polar angle component of the vector position relative to origin using atan2
    double arg() const { return atan2(y, x); }

    // Returns a vector with norm r and having same direction
    PT truncate(double r) const {
        double k = norm();
        if (!sign(k)) return *this;
        r /= k;
        return PT(x * r, y * r);
    }
};

